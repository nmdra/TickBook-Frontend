# Backend gateway URL. The frontend is hosted separately and calls this URL directly.
# Local Docker backend:
VITE_API_BASE_URL=http://localhost:8080

# Hosted backend example:
# VITE_API_BASE_URL=https://nginx-gateway.bravemoss-36d38df2.eastus.azurecontainerapps.io

# Per-service URL overrides. Usually leave these unset so every API call goes
# through the single gateway URL above.
# VITE_EVENT_SERVICE_URL=http://localhost:3001
# VITE_USER_SERVICE_URL=http://localhost:3002
# VITE_BOOKING_SERVICE_URL=http://localhost:3003
# VITE_PAYMENT_SERVICE_URL=http://localhost:3004
